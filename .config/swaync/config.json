{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-width": 400,
  "notification-window-width": 400,
  "timeout": 5,
  "widgets": [
    "title",
    "mpris",
    "buttons-grid",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Sistema",
      "clear-all-button": true,
      "button-text": "Limpiar"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12,
      "title-color": "white",
      "artist-color": "#bbbbbb"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": " ",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && bluetoothctl power on || bluetoothctl power off'",
          "update-command": "sh -c '[[ $(bluetoothctl show | grep \"Powered: yes\" | wc -l) -gt 0 ]] && echo true || echo false'"
        },
        {
          "label": " ",
          "command": "kitty fastfetch"
        },
        {
          "label": " ",
          "command": "sh -c 'rm -rf ~/.cache/* && notify-send \"Sin kk!\" \"no cache\"'"
        },
        {
          "label": " ",
          "command": "systemctl poweroff"
        }
      ]
    },
    "dnd": {
      "text": "No molestar"
    }
  }
}